<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#1C1C1C"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvDegRadMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:letterSpacing="0.05"
            android:text="DEG"
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="start"
            android:gravity="end"
            android:maxLines="2"
            android:paddingBottom="4dp"
            android:text=""
            android:textColor="#666666"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="72sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:background="#222222">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSin"
                style="@style/SciBtn"
                android:text="sin"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnCos"
                style="@style/SciBtn"
                android:text="cos"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnTan"
                style="@style/SciBtn"
                android:text="tan"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnLog"
                style="@style/SciBtn"
                android:text="log"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnLn"
                style="@style/SciBtn"
                android:text="ln"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAsin"
                style="@style/SciBtn"
                android:text="sin⁻¹"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnAcos"
                style="@style/SciBtn"
                android:text="cos⁻¹"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnAtan"
                style="@style/SciBtn"
                android:text="tan⁻¹"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnSqrt"
                style="@style/SciBtn"
                android:text="√"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnSquare"
                style="@style/SciBtn"
                android:text="x²"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPow"
                style="@style/SciBtn"
                android:text="xʸ"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnReciprocal"
                style="@style/SciBtn"
                android:text="1/x"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnFactorial"
                style="@style/SciBtn"
                android:text="n!"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnPi"
                style="@style/SciBtn"
                android:text="π"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnE"
                style="@style/SciBtn"
                android:text="e"
                android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5.5"
        android:orientation="vertical"
        android:background="#2A2A2A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="#222222">

            <Button
                android:id="@+id/btnDegRad"
                style="@style/FuncBtn"
                android:text="DEG"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnOpenParen"
                style="@style/FuncBtn"
                android:text="("
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnCloseParen"
                style="@style/FuncBtn"
                android:text=")"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnPercent"
                style="@style/FuncBtn"
                android:text="%"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnDelete"
                style="@style/FuncBtn"
                android:text="DEL"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn7"
                style="@style/NumBtn"
                android:text="7"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn8"
                style="@style/NumBtn"
                android:text="8"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn9"
                style="@style/NumBtn"
                android:text="9"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnDivide"
                style="@style/OpBtn"
                android:text="÷"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn4"
                style="@style/NumBtn"
                android:text="4"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn5"
                style="@style/NumBtn"
                android:text="5"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn6"
                style="@style/NumBtn"
                android:text="6"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnMultiply"
                style="@style/OpBtn"
                android:text="×"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                style="@style/NumBtn"
                android:text="1"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn2"
                style="@style/NumBtn"
                android:text="2"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn3"
                style="@style/NumBtn"
                android:text="3"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnSubtract"
                style="@style/OpBtn"
                android:text="−"
                android:layout_weight="1"/>

        </LinearLayout>

        <View style="@style/HDiv"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDecimal"
                style="@style/NumBtn"
                android:text="."
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btn0"
                style="@style/NumBtn"
                android:text="0"
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnEquals"
                style="@style/EqBtn"
                android:text="="
                android:layout_weight="1"/>

            <View style="@style/VDiv"/>

            <Button
                android:id="@+id/btnAdd"
                style="@style/OpBtn"
                android:text="+"
                android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>